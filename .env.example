PORT=3000

# LLM agent mode. Defaults to Ollama locally and falls back only when unavailable.
USE_LLM=true
LLM_PROVIDER=ollama

# Optional OpenAI audio pipeline.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_VOICE=marin

# Optional local model settings for Ollama-compatible endpoints.
LOCAL_LLM_MODEL=phi3:mini
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_HEALTH_URL=http://127.0.0.1:11434/api/tags
